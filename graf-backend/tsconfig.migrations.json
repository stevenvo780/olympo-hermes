{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2020",
    "outDir": "./dist",
    "declaration": false,
    "sourceMap": false,
    "resolveJsonModule": true
  },
  "include": [
    "data-source.ts",
    "migrations/**/*.ts",
    "src/migrations/**/*.ts",
    "src/**/*.entity.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}