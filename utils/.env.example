# Env vars for utility scripts. Copy to utils/.env and fill with real values.

# Generic remote -> local sync (sync_db.sh)
REMOTE_DB_HOST=
REMOTE_DB_PORT=5432
REMOTE_DB_USER=
REMOTE_DB_NAME=
REMOTE_DB_PASS=
REMOTE_SSLMODE=require

# Production database (sync_prod_to_local.sh)
PROD_DB_HOST=
PROD_DB_PORT=5432
PROD_DB_USER=
PROD_DB_NAME=
PROD_DB_PASS=
PROD_SSLMODE=require

# Development database (sync_dev_to_local_docker.sh and sync_local_to_dev.sh)
DEV_DB_HOST=
DEV_DB_PORT=5432
DEV_DB_USER=
DEV_DB_NAME=
DEV_DB_PASS=
DEV_SSLMODE=require

# Local database defaults (shared)
LOCAL_DB_HOST=localhost
LOCAL_DB_PORT=5432
LOCAL_DB_USER=postgres
LOCAL_DB_PASS=
LOCAL_DB_NAME=

# Optional overrides per workflow
LOCAL_DB_NAME_DEV_TO_LOCAL=
LOCAL_DB_NAME_LOCAL_TO_DEV=
LOCAL_DB_NAME_PROD_TO_LOCAL=
LOCAL_DB_CONTAINER_NAME=graf-postgres

# Webhook utilities
WEBHOOK_SECRET=
GRAF_WEBHOOK_URL=http://localhost:3007/api/v1/webhooks/graf
