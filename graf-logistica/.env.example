# --- prizma-hermes-logistica — variables de entorno ---

# Base de datos PROPIA del software de logística (desacoplada de Hermes).
# Local desechable (mismo Postgres del demo, base distinta):
DATABASE_URL="postgresql://prizma:prizma@127.0.0.1:55432/hermes_logistica?schema=public"

# Integración con Hermes (solo lectura de pedidos enrutados/despachados).
# Apunta al backend de Hermes (NestJS). En el demo: backend local o túnel.
HERMES_API_URL="http://localhost:3000"

# Auth contra Hermes. En el demo se usa el camino x-api-key del FirebaseAuthGuard.
# En producción se usaría un token de servicio / API key de servidor (NUNCA exponer al cliente).
HERMES_API_KEY="hermes-dist-demo-key-2026"

# Tienda(s) de Hermes con la feature de distribución activa que esta logística atiende.
# Coma-separadas. Cada despacho queda scopeado por storeId.
HERMES_STORE_IDS="hermes-dist"

# Peso promedio por unidad (kg) para estimar el cargue cuando el producto no trae peso.
DEFAULT_UNIT_WEIGHT_KG="1.5"

# Auth de la app de logística (oficina). La UI pide esta contraseña y guarda una
# cookie httpOnly de sesión. Cambiar en cualquier despliegue real.
LOGISTICA_APP_PASSWORD="palomino2026"
# Secreto opaco de la cookie de sesión / clave server-to-server (header x-internal-key).
LOGISTICA_AUTH_TOKEN="cambia-esto-por-un-secreto-largo"
# Clave server-to-server (header x-internal-key) para sync programado. >=16 chars.
LOGISTICA_INTERNAL_KEY="cambia-esto-por-otro-secreto-largo"
# NOTA: sin estas variables la app NO autentica a nadie (fail-closed). No hay defaults.
