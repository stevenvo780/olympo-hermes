{
  "name": "prizma-hermes-logistica",
  "version": "0.1.0",
  "private": true,
  "description": "Software de logística y despacho (cliente Palomino) — capa de cargue a camiones, tablero de despacho y tracking de transportadora. DB propia, integrado a Hermes por API.",
  "scripts": {
    "dev": "next dev -p 4012",
    "build": "prisma generate && NODE_ENV=production next build",
    "start": "next start -p 4012",
    "lint": "next lint",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "prizma-brand": "file:../../../packages/brand",
    "prizma-ui": "file:../../../packages/ui",
    "@prisma/client": "^5.22.0",
    "next": "^15.5.9",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5"
  }
}
